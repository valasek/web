{
  "name": "HugoBlox Codespace",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "0.159.2"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": false
    }
  },
  "postCreateCommand": "rm -rf node_modules package-lock.json && npm install && hugo mod get ./...",
  "postStartCommand": "hugo server --bind 0.0.0.0 --disableFastRender",
  "customizations": {
    "vscode": {
      "extensions": [
        "ownable.ownable"
      ]
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [1313],
  "portsAttributes": {
    "1313": {
      "label": "Hugo Server"
    }
  }
}